rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /workspaces/{workspaceId} {
      allow read, write: if true; // In production, restrict to ownerEmail

      match /users/{userId} {
        allow read, write: if true;
      }
      
      match /system/{docId} {
        allow read, write: if true;
      }
      
      match /products/{productId} {
        allow read, write: if true;
      }
      
      match /departments/{deptId} {
        allow read, write: if true;
      }
      
      match /tasks/{taskId} {
        allow read, write: if true;
      }
      
      match /requests/{reqId} {
        allow read, write: if true;
      }
      
      match /notifications/{notifId} {
        allow read, write: if true;
      }
      
      match /documents/{docId} {
        allow read, write: if true;
      }
      
      match /draft_cart/{cartId} {
        allow read, write: if true;
      }
      
      match /last_view/{viewId} {
        allow read, write: if true;
      }
    }

    match /{document=**} {
      allow read, write: if true; // Temporarily permissive for dev sandbox
    }
  }
}
