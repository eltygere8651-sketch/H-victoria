rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- CRITICAL: QR SESSIONS ---
    match /hotel_victoria_qr_sessions/{sessionId} {
      allow read, write: if true; 
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwnerEmail() {
      return isSignedIn() && request.auth.token.get('email', '').lower() == 'eltygere8651@gmail.com';
    }

    function isSuperAdmin() {
      return isOwnerEmail() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('isSuperAdmin', false) == true
      );
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('role', '') == 'ADMIN'
      );
    }

    function isStaff() {
      return isAdmin() || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)) && 
        (get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('role', '') == 'STAFF' || 
         get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('role', '') == 'ADMIN')
      );
    }

    // --- COLLECTIONS ---

    match /hotel_victoria_users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || userId == request.auth.uid;
    }

    match /hotel_victoria_draft_cart/{cartId} {
      allow read, write: if isSuperAdmin() || (isSignedIn() && (cartId == request.auth.uid || isAdmin()));
    }

    match /hotel_victoria_products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotel_victoria_departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotel_victoria_requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /hotel_victoria_notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /hotel_victoria_tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }
    
    match /hotel_victoria_documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotel_victoria_system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
