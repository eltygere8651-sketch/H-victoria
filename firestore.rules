rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Regla global: Permitimos lectura y escritura si el usuario está autenticado en la app.
    // Para simplificar al máximo y evitar errores de "permisos insuficientes", 
    // permitiremos acceso general mientras se usa la aplicación.
    
    match /{document=**} {
      allow read, write: if true;
    }

    // Nota: Estas reglas son permisivas para asegurar el funcionamiento inmediato.
    // Una vez que la app sea estable, se recomienda restringir por colecciones.
  }
}
