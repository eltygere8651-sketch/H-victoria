rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Safely gets a user's document.
    function getUserDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    // Safely checks if the currently authenticated user is an Admin.
    function isRequestingUserAdmin() {
      let userDoc = getUserDoc(request.auth.uid);
      return isSignedIn() && userDoc != null && userDoc.data.role == 'ADMIN';
    }

    // Safely checks if the requesting user has permissions to manage tasks.
    function canRequestingUserManageTasks() {
      let userDoc = getUserDoc(request.auth.uid);
      return isSignedIn() && userDoc != null && (
        userDoc.data.role == 'ADMIN' ||
        ('permissions' in userDoc.data && 'CAN_MANAGE_TASKS' in userDoc.data.permissions)
      );
    }

    // --- COLLECTION RULES ---

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn();
      // FIX: Allow any signed-in user to create, enabling initial data seeding & admin user creation.
      allow create: if isSignedIn();
      allow delete: if isRequestingUserAdmin();
      allow update: if isRequestingUserAdmin() ||
                      (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pushToken']));
    }

    // DEPARTMENTS
    match /departments/{deptId} {
      allow read: if isSignedIn();
      // FIX: Allow creation for initial data seeding.
      allow create: if isSignedIn();
      allow update, delete: if isRequestingUserAdmin();
    }

    // PRODUCTS
    match /products/{productId} {
      allow read: if isSignedIn();
      // FIX: Allow creation for initial data seeding.
      allow create: if isSignedIn();
      allow delete: if isRequestingUserAdmin();
      allow update: if isRequestingUserAdmin() ||
                      (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantity']));
    }

    // REQUESTS (Order History)
    match /requests/{reqId} {
      allow read, delete: if isRequestingUserAdmin();
      allow create: if isSignedIn();
      allow update: if false;
    }

    // NOTIFICATIONS
    match /notifications/{notifId} {
      allow read, update, delete: if isRequestingUserAdmin();
      allow create: if isSignedIn();
    }

    // TASKS
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create, delete: if canRequestingUserManageTasks();
      allow update: if canRequestingUserManageTasks() ||
                     (isSignedIn() &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .difference(['status', 'completedAt', 'completedBy', 'comments', 'seenBy']).size() == 0
                     );
    }
  }
}
