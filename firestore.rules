rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- BASIC HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the user is a Super Admin
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'JKkdLhni4DM3oRsTJWzgwpkSY6A3' ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'eltygere8651@gmail.com') || 
        (request.auth.token.email != null && request.auth.token.email.lower() == 'hotelvictoria644@gmail.com')
      );
    }

    // Role detection via UID-indexed document
    function getProfileData() {
      return get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data;
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSuperAdmin() || (hasProfile() && (
        getProfileData().get('role', '') == 'ADMIN' || 
        getProfileData().get('role', '') == 'SUPER_ADMIN' ||
        getProfileData().get('isAdmin', false) == true ||
        getProfileData().get('name', '') == 'Administrador'
      ));
    }

    function isStaff() {
      return isAdmin() || (hasProfile() && getProfileData().get('role', '') == 'STAFF');
    }

    function isInitializationPhase() {
      return !exists(/databases/$(database)/documents/hotel_victoria_system/initialization);
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- GLOBAL SAFETY ---
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --- COLLECTIONS ---

    match /hotel_victoria_users/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn() && (
        userId == request.auth.uid ||
        isSuperAdmin() ||
        isAdmin() ||
        isInitializationPhase()
      );
    }

    match /hotel_victoria_products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSuperAdmin() || isInitializationPhase();
      allow update: if isSignedIn() && (
        isAdmin() || 
        isSuperAdmin() || 
        isInitializationPhase() || 
        incoming().diff(existing()).affectedKeys().hasOnly(['quantity'])
      );
    }

    match /hotel_victoria_departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSuperAdmin() || isInitializationPhase();
    }

    match /hotel_victoria_requests/{requestId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin() || isSuperAdmin();
    }

    match /hotel_victoria_notifications/{notifId} {
      allow read, write: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /hotel_victoria_tasks/{taskId} {
      allow read, write: if isSignedIn();
      allow delete: if isAdmin();
    }
    
    match /hotel_victoria_documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotel_victoria_system/{docId} {
      allow read: if isSignedIn();
      allow write: if isInitializationPhase() || isSuperAdmin() || isAdmin();
    }

    match /hotel_victoria_draft_cart/{cartId} {
      allow read, write: if isSignedIn() && (cartId == request.auth.uid || isAdmin());
    }
  }
}
