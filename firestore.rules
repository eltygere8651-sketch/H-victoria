rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- BASIC HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the user is a Super Admin (hardcoded emails)
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '').lower() == 'eltygere8651@gmail.com' || 
        request.auth.token.get('email', '').lower() == 'hotelvictoria644@gmail.com'
      );
    }

    // Role detection via UID-indexed document - Safer version
    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)) && 
        (
          get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('role', '') == 'ADMIN' || 
          get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('isAdmin', false) == true ||
          get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('name', '') == 'Administrador'
        )
      );
    }

    function isStaff() {
      return isAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('role', '') == 'STAFF'
      );
    }

    function isInitializationPhase() {
      return !exists(/databases/$(database)/documents/hotel_victoria_system/initialization);
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- GLOBAL DENY ---
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --- COLLECTIONS ---
    
    // Función rápida para lectura básica sin activar comprobaciones de perfil
    function canReadBasic() {
      return request.auth != null;
    }

    match /hotel_victoria_users/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn() && (
        userId == request.auth.uid ||
        isSuperAdmin() ||
        isAdmin() ||
        isInitializationPhase() ||
        // Permitir vinculación inicial si el documento no tiene UID o es el Administrador base
        !exists(/databases/$(database)/documents/hotel_victoria_users/$(userId)) ||
        get(/databases/$(database)/documents/hotel_victoria_users/$(userId)).data.get('authUid', '') == '' ||
        get(/databases/$(database)/documents/hotel_victoria_users/$(userId)).data.get('name', '') == 'Administrador'
      );
    }

    match /hotel_victoria_products/{productId} {
      allow read: if canReadBasic();
      allow write: if isAdmin() || isSuperAdmin() || isInitializationPhase();
      allow update: if canReadBasic() && (incoming().diff(existing()).affectedKeys().hasOnly(['quantity']) || isAdmin());
    }

    match /hotel_victoria_departments/{deptId} {
      allow read: if canReadBasic();
      allow write: if isAdmin() || isSuperAdmin() || isInitializationPhase();
    }

    match /hotel_victoria_requests/{requestId} {
      allow read: if canReadBasic();
      allow create, update: if canReadBasic();
      allow delete: if isAdmin() || isSuperAdmin();
    }

    match /hotel_victoria_notifications/{notifId} {
      allow read, write: if canReadBasic();
      allow delete: if isAdmin();
    }

    match /hotel_victoria_tasks/{taskId} {
      allow read: if canReadBasic();
      allow write: if isSignedIn(); // Permitir que cualquiera cree/edite tareas para subir fotos
      allow delete: if isAdmin();
    }
    
    match /hotel_victoria_room_posts/{postId} {
      allow read: if canReadBasic();
      allow write: if isSignedIn();
      allow delete: if isAdmin();
    }
    
    match /hotel_victoria_documents/{docId} {
      allow read: if canReadBasic();
      allow write: if isAdmin();
    }

    match /hotel_victoria_system/{docId} {
      allow read: if canReadBasic();
      allow write: if isInitializationPhase() || isAdmin();
    }

    // Borradores
    match /hotel_victoria_draft_cart/{cartId} {
      allow read, write: if isSignedIn() && (cartId == request.auth.uid || isAdmin());
    }
  }
}
