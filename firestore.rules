rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && 
             request.auth.token.get('email', '').lower() == 'eltygere8651@gmail.com';
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('role', '') == 'ADMIN'
      );
    }

    // --- GLOBAL ---
    
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --- COLLECTIONS ---

    match /hotel_victoria_users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && userId == request.auth.uid;
      allow update: if isSuperAdmin() || 
                      userId == request.auth.uid || 
                      (resource.data.get('authUid', '') == request.auth.uid) ||
                      (resource.data.get('authUid', '') == '') ||
                      !( 'authUid' in resource.data ) ||
                      (resource.data.authUid == null);
      allow delete: if isSuperAdmin();
    }

    match /hotel_victoria_draft_cart/{cartId} {
      allow read, write: if isSignedIn() && (cartId == request.auth.uid || isSuperAdmin() || isAdmin());
    }

    match /hotel_victoria_products/{productId} {
      allow read: if isSignedIn();
      allow create, delete: if isSuperAdmin() || isAdmin();
      allow update: if isSuperAdmin() || isAdmin() || 
                      (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantity']));
    }

    match /hotel_victoria_departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isAdmin();
    }

    match /hotel_victoria_requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /hotel_victoria_notifications/{notifId} {
      allow read, write: if isSignedIn();
      allow delete: if isSuperAdmin() || isAdmin();
    }

    match /hotel_victoria_tasks/{taskId} {
      allow read, write: if isSignedIn();
      allow delete: if isSuperAdmin() || isAdmin();
    }
    
    match /hotel_victoria_documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isAdmin();
    }

    match /hotel_victoria_system/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
