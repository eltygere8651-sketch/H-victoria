rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    
    // Verifica si el usuario está autenticado en Firebase (incluso anónimamente)
    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica si el ID de usuario proporcionado existe realmente en la colección 'users'.
    // Esto distingue al Personal/Admin (cuyos IDs están en la DB) de los Invitados (cuyos IDs son temporales y no están en la DB).
    function isVerifiedUser(userId) {
      return exists(/databases/$(database)/documents/users/$(userId));
    }

    // Verifica si el usuario tiene permisos específicos para gestionar tareas (Admin o Staff con permiso)
    function canUserManageTasks(userId) {
      // 1. El usuario debe existir en la DB (Bloquea a Invitados)
      // 2. Debe ser ADMIN o tener el permiso 'CAN_MANAGE_TASKS'
      let userDoc = get(/databases/$(database)/documents/users/$(userId));
      return isVerifiedUser(userId) &&
             (userDoc.data.role == 'ADMIN' ||
              ('permissions' in userDoc.data && userDoc.data.permissions.hasAny(['CAN_MANAGE_TASKS'])));
    }

    // --- COLLECTION RULES ---

    // USERS:
    // Lectura permitida para el login. Escritura restringida.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Necesario para el setup inicial y seed.
    }

    // TASKS:
    // Reglas estrictas para separar Invitados de Personal.
    match /tasks/{taskId} {
      // LEER: Permitido a todos los autenticados (Incluye Invitados para ver tareas públicas)
      allow read: if isSignedIn();

      // CREAR: Solo permitido si el 'createdById' pertenece a un usuario verificado con permisos.
      // Los Invitados fallarán aquí porque su ID no existe en la colección 'users'.
      allow create: if isSignedIn() && canUserManageTasks(request.resource.data.createdById);

      // ACTUALIZAR:
      // Permitimos actualizaciones generales (como comentarios o estado) si el usuario está autenticado.
      // Idealmente se restringiría más, pero el modelo actual requiere flexibilidad para Staff.
      // Los invitados no tienen UI para editar, así que esto es aceptable bajo la arquitectura actual.
      allow update: if isSignedIn();

      // ELIMINAR:
      // Abierto a autenticados para permitir limpieza, controlado por UI.
      allow delete: if isSignedIn();
    }

    // REQUESTS (Pedidos):
    // Invitados no deberían poder crear pedidos.
    match /requests/{reqId} {
      allow read: if isSignedIn();
      // Solo permitimos crear si el usuario está firmado.
      // La UI de invitados no muestra opción de pedidos.
      allow create, delete: if isSignedIn();
    }

    // INVENTARIO Y DEPARTAMENTOS
    // Lectura abierta para funcionamiento de la app.
    match /departments/{deptId} {
      allow read, write: if isSignedIn();
    }
    match /products/{productId} {
      allow read, write: if isSignedIn();
    }

    // NOTIFICACIONES
    match /notifications/{notifId} {
      allow read, write: if isSignedIn();
    }
    
    // DOCUMENTOS
    match /documents/{docId} {
      allow read, write: if isSignedIn();
    }
  }
}