rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS BÁSICOS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Un usuario es Super Admin si está en la lista blanca por email
    function isSuperAdmin() {
      let email = request.auth.token.get('email', '').lower();
      return isSignedIn() && email == 'eltygere8651@gmail.com';
    }

    // Role detection via UID-indexed document
    function hasRole(role) {
      let userPath = /databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid);
      return isSignedIn() && exists(userPath) && (
        get(userPath).data.get('role', '').upper() == role.upper() || 
        get(userPath).data.get('role', '').upper() == 'SUPER_ADMIN'
      );
    }

    function isAdmin() {
      let userPath = /databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid);
      return isSuperAdmin() || (
        isSignedIn() && exists(userPath) && (
          get(userPath).data.get('role', '').upper() == 'ADMIN' ||
          get(userPath).data.get('role', '').upper() == 'SUPER_ADMIN' ||
          get(userPath).data.get('isAdmin', false) == true
        )
      );
    }

    function isStaff() {
      return isAdmin() || hasRole('STAFF');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- GLOBAL ---
    
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --- COLLECTIONS ---

    match /hotel_victoria_users/{userId} {
      allow read: if isSignedIn();
      
      // Permitir creación:
      // 1. Perfil propio (userId es su UID - necesario para vincular Auth con perfil de PIN)
      // 2. Registro de nuevo empleado (rol STAFF, sin poderes de admin)
      // 3. Admin creando cualquier usuario
      allow create: if isSignedIn() && (
        userId == request.auth.uid || 
        (incoming().get('role', '') == 'STAFF' && incoming().get('isSuperAdmin', false) == false) ||
        isAdmin()
      );
      
      // Permitir actualización: 
      // 1. Propietario (userId es su UID)
      // 2. Vinculado (el documento tiene su authUid)
      // 3. Admin/SuperAdmin
      allow update: if isSignedIn() && (
        userId == request.auth.uid || 
        existing().get('authUid', '') == request.auth.uid ||
        isAdmin() ||
        (existing().get('authUid', '') == '' && incoming().get('authUid', '') == request.auth.uid)
      );
                        
      allow delete: if isAdmin();
    }

    // Carritos de borrador (Cualquier Admin o el dueño)
    match /hotel_victoria_draft_cart/{cartId} {
      allow read, write: if isSignedIn() && (cartId == request.auth.uid || isAdmin());
    }

    match /hotel_victoria_products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['quantity']));
    }

    match /hotel_victoria_departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotel_victoria_requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /hotel_victoria_notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /hotel_victoria_tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }
    
    match /hotel_victoria_documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotel_victoria_system/{docId} {
      allow read: if isSignedIn();
      // Permitir inicialización si el documento no existe (primera ejecución) o es admin
      allow write: if !exists(/databases/$(database)/documents/hotel_victoria_system/initialization) || isAdmin();
    }
  }
}
