rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    // WARNING: THE FOLLOWING FUNCTIONS CANNOT SECURELY VERIFY THE REQUESTING USER'S ROLE.
    // This application's authentication model (anonymous auth + PIN login) does not
    // provide a verifiable link between the authenticated user (request.auth.uid) and
    // their role in the 'users' collection.
    // Therefore, these rules TRUST THE CLIENT-SIDE APPLICATION to enforce admin/staff logic.
    // A malicious user could bypass the client UI and perform actions they are not
    // authorized for. These rules provide basic data validation but are not a substitute
    // for a proper authentication system (e.g., Firebase Auth with Custom Claims).

    // This function checks if a given user ID corresponds to a user with task management permissions.
    // It is used to validate the data being written, not the identity of the requester.
    function canUserManageTasks(userId) {
      let userDoc = get(/databases/$(database)/documents/users/$(userId));
      return exists(/databases/$(database)/documents/users/$(userId)) &&
             (userDoc.data.role == 'ADMIN' ||
              ('permissions' in userDoc.data && userDoc.data.permissions.hasAny(['CAN_MANAGE_TASKS'])));
    }

    // --- COLLECTION RULES ---

    // USERS
    // A user can update their own pushToken. Other writes are allowed for app functionality
    // but are not secure. The initial data seeding requires open create access.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn(); // DANGER: Not secure. Required for app functionality and seeding.
      allow update: if isSignedIn() ||
                      (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pushToken']));
    }

    // DEPARTMENTS
    // Writes are not secure but are required for admin functionality in the app.
    match /departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // DANGER: Not secure. Required for seeding/functionality.
    }

    // PRODUCTS
    // Any signed-in user can update quantity for placing orders.
    // Other writes are not secure.
    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn(); // DANGER: Not secure. Required for seeding/functionality.
      allow update: if isSignedIn(); // Allows both admin edits and quantity updates.
    }

    // REQUESTS (Order History)
    // Any user can create. Read/delete should be admin-only but cannot be enforced.
    match /requests/{reqId} {
      allow create: if isSignedIn();
      allow read, delete: if isSignedIn(); // DANGER: Not secure.
      allow update: if false; // Requests are immutable.
    }

    // NOTIFICATIONS
    match /notifications/{notifId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn(); // DANGER: Not secure.
    }

    // TASKS
    // These rules offer more robust validation than other collections.
    match /tasks/{taskId} {
      allow read: if isSignedIn();

      // CREATE: The 'createdById' field in the new task MUST belong to a user
      // who actually has permissions to manage tasks. This prevents a user without
      // permissions from creating a task, even if they forge their own ID.
      allow create: if isSignedIn() &&
                      canUserManageTasks(request.resource.data.createdById);

      // DELETE: Relaxed rule - any authenticated user can now delete a task.
      allow delete: if isSignedIn();

      // UPDATE: A task can be updated by a manager, OR any user can update specific
      // fields related to task progression (status, comments, seenBy).
      allow update: if isSignedIn() &&
                      (
                        canUserManageTasks(resource.data.createdById) ||
                        request.resource.data.diff(resource.data).affectedKeys()
                          .difference(['status', 'completedAt', 'completedBy', 'comments', 'seenBy']).size() == 0
                      );
    }
    
    // DOCUMENTS
    // Any signed-in user can read. Writes are not secure.
    match /documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // DANGER: Not secure. Required for admin functionality.
    }
  }
}