rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && (
        (request.auth.token.get('email', '').lower() == 'eltygere8651@gmail.com') ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'eltygere8651@gmail.com')
      );
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('role', '') == 'ADMIN'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && (
        userId == request.auth.uid || 
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/hotel_victoria_users/$(userId)) && (
          get(/databases/$(database)/documents/hotel_victoria_users/$(userId)).data.get('authUid', '') == request.auth.uid ||
          get(/databases/$(database)/documents/hotel_victoria_users/$(userId)).data.get('authUid', '') == '' ||
          get(/databases/$(database)/documents/hotel_victoria_users/$(userId)).data.get('authUid', null) == null
        ))
      );
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- GLOBAL ---
    
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --- COLLECTIONS ---

    match /hotel_victoria_users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || userId == request.auth.uid || isOwner(userId);
    }

    match /hotel_victoria_products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['quantity'])
      );
    }

    match /hotel_victoria_departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotel_victoria_requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /hotel_victoria_notifications/{notifId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /hotel_victoria_tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /hotel_victoria_system/{configId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /hotel_victoria_documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
