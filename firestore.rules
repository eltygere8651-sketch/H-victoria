rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS BÁSICOS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Lista de correos con poder total (Super Admins de código)
    function isWhiteListedSuperAdmin() {
      let email = request.auth.token.get('email', '').lower();
      return email in [
        'eltygere8651@gmail.com'
        // Añade más correos aquí
      ];
    }

    // Un usuario es Super Admin si está en la lista blanca o tiene el flag en su doc
    function isSuperAdmin() {
      let email = request.auth.token.get('email', '').lower();
      let isVerified = request.auth.token.get('email_verified', false) == true;
      let isWhiteListed = email in ['eltygere8651@gmail.com'];
      
      let userPath = /databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid);
      
      return isSignedIn() && (
        (isWhiteListed && isVerified) || 
        (exists(userPath) && (
          get(userPath).data.get('isSuperAdmin', false) == true || 
          get(userPath).data.get('role', '') == 'SUPER_ADMIN'
        ))
      );
    }

    // Role detection via UID-indexed document
    function hasRole(role) {
      let userPath = /databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid);
      let userRole = get(userPath).data.get('role', '').upper();
      let isAdminFlag = get(userPath).data.get('isAdmin', false) == true;
      
      return isSignedIn() && exists(userPath) && (
        userRole == role.upper() || 
        (role.upper() == 'ADMIN' && (isAdminFlag || userRole == 'SUPER_ADMIN' || userRole == 'CREADOR'))
      );
    }

    function isAdmin() {
      return isSuperAdmin() || hasRole('ADMIN');
    }

    function isStaff() {
      return hasRole('STAFF') || hasRole('ADMIN') || isSuperAdmin();
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- GLOBAL ---
    
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --- COLLECTIONS ---

    match /hotel_victoria_users/{userId} {
      allow read: if isSignedIn();
      
      // Permitir creación de perfil propio o por parte de un admin
      allow create: if (isSignedIn() && userId == request.auth.uid) || isAdmin();
      
      // Permitir actualización con restricciones
      allow update: if (
        // 1. EL PROPIETARIO DEL CORREO MAESTRO: Puede cambiarlo TODO
        isWhiteListedSuperAdmin() || 
        
        // 2. OTROS ADMINS: Pueden gestionar usuarios
        isAdmin() ||
        
        // 3. USUARIO PROPIO
        (isSignedIn() && (userId == request.auth.uid || resource.data.get('authUid', '') == request.auth.uid))
      );
                       
      allow delete: if isAdmin();
    }

    // Carritos de borrador (Cualquier Admin o el dueño)
    match /hotel_victoria_draft_cart/{cartId} {
      allow read, write: if isSignedIn() && (cartId == request.auth.uid || isAdmin());
    }

    match /hotel_victoria_products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['quantity']));
    }

    match /hotel_victoria_departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotel_victoria_requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /hotel_victoria_notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /hotel_victoria_tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }
    
    match /hotel_victoria_documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotel_victoria_system/{docId} {
      allow read: if isSignedIn();
      // Permitir inicialización si el documento no existe (primera ejecución) o es admin
      allow write: if !exists(/databases/$(database)/documents/hotel_victoria_system/initialization) || isAdmin();
    }
  }
}
