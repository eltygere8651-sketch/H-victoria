rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS BÁSICOS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Lista de correos con poder total (Super Admins de código)
    function isWhiteListedSuperAdmin() {
      return isSignedIn() && 
             request.auth.token.get('email', '').lower() == 'eltygere8651@gmail.com';
    }

    // Un usuario es Super Admin si está en la lista blanca o tiene el flag en su doc
    function isSuperAdmin() {
      return isSignedIn() && (
        isWhiteListedSuperAdmin() || 
        (exists(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('isSuperAdmin', false) == true)
      );
    }

    // Role detection via UID-indexed document
    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('role', '') == role;
    }

    function isAdmin() {
      return isSuperAdmin() || hasRole('ADMIN');
    }

    function isStaff() {
      return hasRole('STAFF') || hasRole('ADMIN') || isSuperAdmin();
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- GLOBAL ---
    
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --- COLLECTIONS ---

    match /hotel_victoria_users/{userId} {
      allow read: if isSignedIn();
      
      // Permitir creación de perfil propio
      allow create: if isSignedIn() && userId == request.auth.uid;
      
      // Permitir actualización con restricciones
      allow update: if isSuperAdmin() || (
        isSignedIn() && (
          // El usuario puede actualizar su propio perfil PERO NO sus roles
          (userId == request.auth.uid || resource.data.get('authUid', '') == request.auth.uid) && 
          !incoming().diff(existing()).affectedKeys().hasAny(['role', 'isSuperAdmin', 'isAdmin'])
        ) ||
        // Permitir vinculación inicial (cuando authUid está vacío)
        (resource.data.get('authUid', '') == '' || !('authUid' in resource.data))
      );
                      
      allow delete: if isSuperAdmin();
    }

    // Carritos de borrador (Cualquier Admin o el dueño)
    match /hotel_victoria_draft_cart/{cartId} {
      allow read, write: if isSignedIn() && (cartId == request.auth.uid || isAdmin());
    }

    // Sesiones de Login por QR
    match /hotel_victoria_qr_sessions/{sessionId} {
      allow read, write: if true; 
    }

    match /hotel_victoria_products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['quantity']));
    }

    match /hotel_victoria_departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotel_victoria_requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /hotel_victoria_notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /hotel_victoria_tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }
    
    match /hotel_victoria_documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotel_victoria_system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
