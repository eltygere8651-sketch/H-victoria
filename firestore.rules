rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          // Owner bypass via Google Auth
          (request.auth.token.email == "eltygere8651@gmail.com") ||
          // Check if there's a user document with this UID and role ADMIN
          (exists(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.role == 'ADMIN')
        );
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /hotel_victoria_users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.role == 'STAFF';
      allow update, delete: if isAdmin();
    }

    match /hotel_victoria_departments/{deptId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /hotel_victoria_products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /hotel_victoria_requests/{reqId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /hotel_victoria_tasks/{taskId} {
      allow get: if true;
      allow list: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /hotel_victoria_scheduled_tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /hotel_victoria_notifications/{notifId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /hotel_victoria_documents/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /hotel_victoria_system/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /hotel_victoria_rooms/{roomId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /hotel_victoria_tables/{tableId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /hotel_victoria_reservations/{resId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
