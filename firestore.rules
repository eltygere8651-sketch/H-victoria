rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- BASIC HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the user is a Super Admin (hardcoded emails)
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '').lower() == 'eltygere8651@gmail.com' || 
        request.auth.token.get('email', '').lower() == 'hotelvictoria644@gmail.com'
      );
    }

    // Role detection via UID-indexed document
    function getProfile() {
      return get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data;
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSuperAdmin() || (hasProfile() && (
        getProfile().get('role', '') == 'ADMIN' || 
        getProfile().get('role', '') == 'SUPER_ADMIN' ||
        getProfile().get('isAdmin', false) == true ||
        getProfile().get('name', '') == 'Administrador'
      ));
    }

    function isStaff() {
      return isAdmin() || (hasProfile() && getProfile().get('role', '') == 'STAFF');
    }

    function isInitializationPhase() {
      return !exists(/databases/$(database)/documents/hotel_victoria_system/initialization);
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- GLOBAL DENY ---
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --- COLLECTIONS ---

    match /hotel_victoria_users/{userId} {
      allow read, write: if isSignedIn();
    }

    match /hotel_victoria_products/{productId} {
      allow read: if isSignedIn();
      // Allow writes if Admin OR if no initialization doc exists OR if self-identified as Administrador
      allow write: if isAdmin() || 
                   isSuperAdmin() ||
                   isInitializationPhase() || 
                   (isSignedIn() && hasProfile() && getProfile().get('name', '') == 'Administrador');
      allow update: if isAdmin() || isSuperAdmin() || isInitializationPhase() || (isSignedIn() && (incoming().diff(existing()).affectedKeys().hasOnly(['quantity']) || (hasProfile() && getProfile().get('name', '') == 'Administrador')));
    }

    match /hotel_victoria_departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSuperAdmin() || isInitializationPhase();
    }

    match /hotel_victoria_requests/{requestId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin() || isSuperAdmin();
    }

    match /hotel_victoria_notifications/{notifId} {
      allow read, write: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /hotel_victoria_event_halls/{hallId} {
      allow read, write: if isSignedIn();
    }

    match /hotel_victoria_tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isStaff() || isSignedIn(); // Permiso extendido para desarrollo
      allow delete: if isAdmin() || isSignedIn();
    }
    
    match /hotel_victoria_documents/{docId} {
      allow read, write: if isSignedIn();
    }

    match /hotel_victoria_system/{docId} {
      allow read, write: if isSignedIn();
    }

    // Borradores
    match /hotel_victoria_draft_cart/{cartId} {
      allow read, write: if isSignedIn() && (cartId == request.auth.uid || isAdmin());
    }
  }
}
