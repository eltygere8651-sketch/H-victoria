rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS BÁSICOS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Un usuario es Super Admin si está en la lista blanca por email
    function isSuperAdmin() {
      let email = request.auth.token.get('email', '').lower();
      return isSignedIn() && email == 'eltygere8651@gmail.com';
    }

    // Role detection via UID-indexed document
    function hasRole(role) {
      let userPath = /databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid);
      return isSignedIn() && exists(userPath) && (
        get(userPath).data.get('role', '').upper() == role.upper() || 
        get(userPath).data.get('role', '').upper() == 'SUPER_ADMIN'
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('isAdmin', false) == true ||
          get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('role', '') == 'ADMIN' ||
          get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('role', '') == 'SUPER_ADMIN'
        ))
      );
    }

    function isStaff() {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data.get('role', '') == 'STAFF')
      );
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- GLOBAL ---
    
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --- COLLECTIONS ---

    match /hotel_victoria_users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      
      // Permitir creación simplificada: cualquier usuario autenticado puede crear un perfil
      // solo validamos que no se den permisos de admin a sí mismos
      allow create: if isSignedIn() && 
        incoming().get('isAdmin', false) == false && 
        incoming().get('isSuperAdmin', false) == false;
      
      allow update: if isSignedIn() && (
        userId == request.auth.uid || 
        existing().get('authUid', '') == request.auth.uid ||
        isAdmin()
      );
                        
      allow delete: if isAdmin();
    }

    // Carritos de borrador (Cualquier Admin o el dueño)
    match /hotel_victoria_draft_cart/{cartId} {
      allow read, write: if isSignedIn() && (cartId == request.auth.uid || isAdmin());
    }

    match /hotel_victoria_products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['quantity']));
    }

    match /hotel_victoria_departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotel_victoria_requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /hotel_victoria_notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /hotel_victoria_tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }
    
    match /hotel_victoria_documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotel_victoria_system/{docId} {
      allow read: if isSignedIn();
      // Permitir inicialización si el documento no existe (primera ejecución) o es admin
      allow write: if !exists(/databases/$(database)/documents/hotel_victoria_system/initialization) || isAdmin();
    }
  }
}
