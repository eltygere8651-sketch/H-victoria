rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 1. Regla para Tareas
    match /task-images/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // 2. Regla para Documentos
    match /documents/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}