rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- GLOBAL SAFETY NET ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Super Admin detection (using hardcoded emails/UIDs as per project context)
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'JKkdLhni4DM3oRsTJWzgwpkSY6A3' ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'eltygere8651@gmail.com') || 
        (request.auth.token.email != null && request.auth.token.email.lower() == 'hotelvictoria644@gmail.com')
      );
    }

    function getProfileData() {
      return get(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid)).data;
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/hotel_victoria_users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSuperAdmin() || (hasProfile() && (
        getProfileData().get('role', '') == 'ADMIN' || 
        getProfileData().get('role', '') == 'SUPER_ADMIN' ||
        getProfileData().get('isAdmin', false) == true
      ));
    }

    function isStaff() {
      return isAdmin() || (hasProfile() && getProfileData().get('role', '') == 'STAFF');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- VALIDATION HELPERS ---

    function isValidTask(data) {
      return data.title is string && data.title.size() >= 1 && data.title.size() <= 200 &&
             data.type in ['TASK', 'DAILY', 'RESERVATION', 'ANNOUNCEMENT'] &&
             (data.get('reservationDate', '') is string && data.get('reservationDate', '').size() <= 12) &&
             (data.get('location', '') is string && data.get('location', '').size() <= 50);
    }

    // --- COLLECTIONS ---

    match /hotel_victoria_users/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isSuperAdmin() || isAdmin();
      allow update: if isSignedIn() && userId == request.auth.uid && !incoming().diff(existing()).affectedKeys().hasAny(['role', 'isAdmin', 'authUid']);
    }

    match /hotel_victoria_tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidTask(incoming());
      allow update: if isSignedIn() && isValidTask(incoming()) && (
        isAdmin() || 
        (isStaff() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'clientArrived', 'arrivedAt', 'completedBy', 'completedAt', 'comments', 'seenBy']))
      );
      allow delete: if isAdmin();
    }

    match /hotel_victoria_products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      allow update: if isStaff() && incoming().diff(existing()).affectedKeys().hasOnly(['quantity']);
    }

    match /hotel_victoria_departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotel_victoria_requests/{requestId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /hotel_victoria_notifications/{notifId} {
      allow read, write: if isSignedIn();
    }

    match /hotel_victoria_system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotel_victoria_draft_cart/{cartId} {
      allow read, write: if isSignedIn() && (cartId == request.auth.uid || isAdmin());
    }
    
    match /hotel_victoria_documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
